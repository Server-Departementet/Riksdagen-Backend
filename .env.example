# Connection string to the backend's OWN MariaDB database (hosts the User + Quote tables).
# The web app reads the Quote table from this DB over LAN.
DATABASE_URL="mysql://user:password@host:3306/riksdagen_bot"

# Connection string to the web app's database (User, SpotifyAccount, music tables).
# Used by make-users (minister sync) and post-recent-plays.
WEB_DATABASE_URL="mysql://user:password@host:3306/riksdagen"

# Spotify app credentials, used to refresh the tokens ministers connected via the web app
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# Port for the asset server (systemd/assets.service) serving public/quote-attachments
# to the web VMs. Optional, defaults to 3100.
ASSETS_PORT="3100"

# Discord bot credentials
DISCORD_BOT_TOKEN=""
DISCORD_BOT_CLIENT_ID=""

# Regeringen guild + channels
REGERINGEN_GUILD_ID=""
QUOTE_CHANNEL_ID=""
QUIZ_CHANNEL_ID=""

# Public base URL used to build attachment image links in quiz embeds
CANONICAL_URL="https://riksdagen.net"

# Discgolf bot guild + channels
DISCGOLF_GUILD_ID=""
DISCGOLF_READ_CHANNEL_ID=""
DISCGOLF_WRITE_CHANNEL_ID=""

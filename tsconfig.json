{
  "compilerOptions": {
    "noEmit": true,
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowUnreachableCode": false,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node",
    ],
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
  ],
}
{
  "compilerOptions": {
    "noEmit": true,
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowUnreachableCode": false,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": [
        "./src/*",
      ],
    },
    "types": [
      "node",
    ],
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
  ],
}